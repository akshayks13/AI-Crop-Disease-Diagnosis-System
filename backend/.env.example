# Environment Configuration
# Copy this file to .env and update values as needed

# Database - Update with your PostgreSQL credentials
DATABASE_URL=postgresql+asyncpg://your_username:your_password@localhost:5432/crop_diagnosis

# JWT Configuration
JWT_SECRET_KEY=dev-secret-key-change-in-production-abc123xyz789
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
OTP_EXPIRE_MINUTES=5

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Cloudinary Storage (recommended for production uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_SECURE=true
CLOUDINARY_FOLDER=crop_diagnosis

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# App
APP_NAME=AI Crop Disease Diagnosis System
DEBUG=true

# External APIs
AGMARKNET_API_KEY=your-api-key
AGMARKNET_API_URL=https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070

# Email (OTP Delivery)
# Example for Gmail App Password:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=akshayks130605@gmail.com
SMTP_PASSWORD=vraz eotp sefl hviq
SMTP_FROM_EMAIL=akshayks130605@gmail.com
SMTP_FROM_NAME=AI Crop Disease Diagnosis
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Redis Cache (optional — leave empty to use in-memory fallback)
# Run Redis locally: docker run -d -p 6379:6379 --name redis redis:7-alpine
REDIS_URL=redis://localhost:6379/0
