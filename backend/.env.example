# Environment Configuration
# Copy this file to .env and update values as needed

# Database - Update with your PostgreSQL credentials
DATABASE_URL=postgresql+asyncpg://postgres:12345@localhost:5432/crop_diagnosis

# JWT Configuration
JWT_SECRET_KEY=dev-secret-key-change-in-production-abc123xyz789
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# App
APP_NAME=AI Crop Disease Diagnosis System
DEBUG=true

# External APIs
AGMARKNET_API_KEY = your-api-key
AGMARKNET_API_URL=https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070
